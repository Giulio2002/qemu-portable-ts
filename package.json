{
  "name": "qemu-ts-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Monorepo for @org/qemu — TypeScript API over vendored QEMU binaries",
  "workspaces": [
    "packages/qemu"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspace @org/qemu",
    "typecheck": "npm run typecheck --workspace @org/qemu",
    "test": "npm run test --workspace @org/qemu",
    "verify:packages": "node --experimental-strip-types scripts/verify-binary-package.ts",
    "verify:licenses": "node --experimental-strip-types scripts/verify-license-files.ts",
    "smoke": "node --experimental-strip-types scripts/smoke-test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
