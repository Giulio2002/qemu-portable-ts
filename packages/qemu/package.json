{
  "name": "qemu-portable",
  "version": "0.1.0",
  "description": "TypeScript API for vendored QEMU binaries",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "qemu-portable": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "COMPLIANCE.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "pretest": "tsc -p tsconfig.test.json",
    "test": "node run-tests.js"
  },
  "optionalDependencies": {
    "@qemu-portable/linux-x64": "0.1.0",
    "@qemu-portable/linux-arm64": "0.1.0",
    "@qemu-portable/linux-x64-musl": "0.1.0",
    "@qemu-portable/linux-arm64-musl": "0.1.0",
    "@qemu-portable/darwin-arm64": "0.1.0",
    "@qemu-portable/darwin-x64": "0.1.0",
    "@qemu-portable/win32-x64": "0.1.0",
    "@qemu-portable/win32-arm64": "0.1.0"
  },
  "license": "MIT"
}
